    "#| label: accuracy-metrics\n",
    "#| echo: true\n",
    "\n",
    "import numpy as np\n",
    "\n",
    "def wmape(y, yhat):\n",
    "    # WMAPE: Weighted Mean Absolute Percentage Error\n",
    "    return np.sum(np.abs(y - yhat)) / np.sum(np.abs(y)) * 100\n",
    "\n",
    "def rmse(y, yhat):\n",
    "    # RMSE: Root Mean Squared Error\n",
    "    return np.sqrt(np.mean((y - yhat)**2))\n",
    "\n",
    "def mae(y, yhat):\n",
    "    # MAE: Mean Absolute Error\n",
    "    return np.mean(np.abs(y - yhat))\n",
    "\n",
    "y_true = train_dt['Price']\n",
    "y_pred = model_reg.fittedvalues \n",
    "\n",
    "print(f\"In-sample WMAPE: {wmape(y_true, y_pred):.2f}%\")\n",
    "print(f\"In-sample RMSE:  {rmse(y_true, y_pred):.2f}\")\n",
    "print(f\"In-sample MAE:   {mae(y_true, y_pred):.2f}\")"
