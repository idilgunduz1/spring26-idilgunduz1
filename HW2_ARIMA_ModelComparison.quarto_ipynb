    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: wmape-breakdown\n",
        "#| fig-cap: WMAPE by hour of day\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "# Calculate WMAPE by hour of day\n",
        "hourly_wmape = comparison_df.groupby('hour').apply(\n",
        "    lambda x: pd.Series({\n",
        "        'WMAPE_naive': wmape(x['actual'], x['naive']),\n",
        "        'WMAPE_reg': wmape(x['actual'], x['regression']),\n",
        "        'WMAPE_arima': wmape(x['actual'], x['forecast'])\n",
        "    })\n",
        ").reset_index()\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(12, 5))\n",
        "\n",
        "x = hourly_wmape['hour']\n",
        "width = 0.25\n",
        "\n",
        "ax.bar(x - width, hourly_wmape['WMAPE_naive'], width, label='Seasonal Naive', alpha=0.8)\n",
        "ax.bar(x, hourly_wmape['WMAPE_reg'], width, label='Regression', alpha=0.8)\n",
        "ax.bar(x + width, hourly_wmape['WMAPE_arima'], width, label='ARIMA/SARIMA', alpha=0.8)\n",
        "\n",
        "ax.set_xlabel('Hour of Day')\n",
        "ax.set_ylabel('WMAPE (%)')\n",
        "ax.set_title('WMAPE Breakdown by Hour of Day')\n",
        "ax.set_xticks(range(0, 24, 2))\n",
        "ax.legend()\n",
        "ax.grid(axis='y', alpha=0.3)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# Also by day of week\n",
        "dow_wmape = comparison_df.copy()\n",
        "dow_wmape['day_of_week'] = pd.to_datetime(dow_wmape['date']).dt.day_name()\n",
        "dow_wmape = dow_wmape.groupby('day_of_week').apply(\n",
        "    lambda x: pd.Series({\n",
        "        'WMAPE_naive': wmape(x['actual'], x['naive']),\n",
        "        'WMAPE_reg': wmape(x['actual'], x['regression']),\n",
        "        'WMAPE_arima': wmape(x['actual'], x['forecast'])\n",
        "    })\n",
        ").reset_index()\n",
        "\n",
        "print(\"\\nWMAPE by Day of Week:\")\n",
        "print(dow_wmape.to_string(index=False))"
      ],
      "id": "wmape-breakdown",
