        "\n",
        "# ACF of seasonally differenced data\n",
        "plot_acf(df['Price_diff24'].dropna(), lags=168, ax=ax[0])\n",
        "ax[0].set_title('ACF of Seasonally Differenced Series (m=24)')\n",
        "\n",
        "# PACF of seasonally differenced data\n",
        "plot_pacf(df['Price_diff24'].dropna(), lags=168, ax=ax[1], method='ywm')\n",
