        "#| label: feature-engineering\n",
        "#| echo: true\n",
        "\n",
        "# 1. Calendar Features \n",
        "df['hour']  = df['Date'].dt.hour\n",
        "df['wday']  = df['Date'].dt.weekday\n",
        "df['month'] = df['Date'].dt.month\n",
